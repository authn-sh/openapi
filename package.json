{
  "name": "@authn.sh/openapi",
  "version": "0.0.0",
  "private": true,
  "description": "OpenAPI 3.1 specification for the authn.sh BAPI and FAPI. Source of truth for SDK code generation.",
  "license": "AGPL-3.0-only",
  "homepage": "https://github.com/authn-sh/openapi",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/authn-sh/openapi.git"
  },
  "bugs": {
    "url": "https://github.com/authn-sh/openapi/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "lint": "redocly lint openapi.yaml",
    "bundle": "npm run bundle:yaml && npm run bundle:json",
    "bundle:yaml": "redocly bundle openapi.yaml -o dist/openapi.bundled.yaml --ext yaml",
    "bundle:json": "redocly bundle openapi.yaml -o dist/openapi.bundled.json --ext json",
    "preview": "redocly preview-docs openapi.yaml",
    "stats": "redocly stats openapi.yaml"
  },
  "devDependencies": {
    "@redocly/cli": "^1.34.0"
  }
}
